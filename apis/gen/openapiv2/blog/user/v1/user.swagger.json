          "$ref": "#/definitions/v1User"
        }
      },
      "description": "UpdateUserResponse returns the updated user."
    },
    "v1User": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "int64"
        },
        "username": {
          "type": "string"
        },
        "nickname": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "emailVerifiedTime": {
          "type": "string",
          "format": "date-time"
        },
        "phone": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/v1UserStatus"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "deletedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "User describes the public profile and account state for a user."
    },
    "v1UserStatus": {
      "type": "string",
      "enum": [
        "USER_STATUS_UNSPECIFIED",
        "USER_STATUS_ACTIVE",
        "USER_STATUS_DISABLE"
      ],
      "default": "USER_STATUS_UNSPECIFIED",
      "description": "UserStatus describes the lifecycle state of a user account."
    }
